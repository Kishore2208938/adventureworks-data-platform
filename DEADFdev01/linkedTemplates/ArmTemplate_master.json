{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "DEADFdev01"
		},
		"LS_ADLS_GEN2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_GEN2'"
		},
		"LS_ADLS_GEN2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://deadlsdev01.dfs.core.windows.net/"
		},
		"ls_AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://DEkvPassword.vault.azure.net/"
		},
		"ls_SqlServer_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-IEPVL3O"
		},
		"ls_SqlServer_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AdventureWorks2016"
		},
		"ls_SqlServer_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "kkadmin"
		},
		"ls_SqlServer_FW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-IEPVL3O"
		},
		"ls_SqlServer_FW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AW_ETL_Framework"
		},
		"ls_SqlServer_FW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "kkadmin"
		},
		"integrationRuntime1_properties_typeProperties_linkedInfo_resourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/e156384c-6302-43fc-b4aa-3e78e0d08c80/resourcegroups/rg_dev/providers/Microsoft.DataFactory/factories/kkadvdevadf/integrationruntimes/SelfhostedintegrationRuntime"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "DEADFdev01_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_GEN2_accountKey": {
						"value": "[parameters('LS_ADLS_GEN2_accountKey')]"
					},
					"LS_ADLS_GEN2_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_GEN2_properties_typeProperties_url')]"
					},
					"ls_AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"integrationRuntime1_properties_typeProperties_linkedInfo_resourceId": {
						"value": "[parameters('integrationRuntime1_properties_typeProperties_linkedInfo_resourceId')]"
					},
					"ls_SqlServer_properties_typeProperties_server": {
						"value": "[parameters('ls_SqlServer_properties_typeProperties_server')]"
					},
					"ls_SqlServer_properties_typeProperties_database": {
						"value": "[parameters('ls_SqlServer_properties_typeProperties_database')]"
					},
					"ls_SqlServer_properties_typeProperties_userName": {
						"value": "[parameters('ls_SqlServer_properties_typeProperties_userName')]"
					},
					"ls_SqlServer_FW_properties_typeProperties_server": {
						"value": "[parameters('ls_SqlServer_FW_properties_typeProperties_server')]"
					},
					"ls_SqlServer_FW_properties_typeProperties_database": {
						"value": "[parameters('ls_SqlServer_FW_properties_typeProperties_database')]"
					},
					"ls_SqlServer_FW_properties_typeProperties_userName": {
						"value": "[parameters('ls_SqlServer_FW_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}